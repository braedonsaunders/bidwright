generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Multi-tenancy Root ────────────────────────────────────────────────────

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  settings         OrganizationSettings?
  users            User[]
  sessions         Session[]
  projects         Project[]
  catalogs         Catalog[]
  plugins          Plugin[]
  entityCategories EntityCategory[]
  conditionLibrary ConditionLibraryEntry[]
  knowledgeBooks   KnowledgeBook[]
  datasets         Dataset[]
  rateSchedules    RateSchedule[]
  customers        Customer[]
  departments      Department[]
  labourCostTables LabourCostTable[]
  burdenPeriods    BurdenPeriod[]
  travelPolicies   TravelPolicy[]
  estimatorPersonas EstimatorPersona[]
}

model OrganizationSettings {
  id             String       @id @default(cuid())
  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  general        Json         @default("{}")
  email          Json         @default("{}")
  defaults       Json         @default("{}")
  integrations   Json         @default("{}")
  brand          Json         @default("{}")
  maxUsers       Int          @default(0) // 0 = unlimited
  maxProjects    Int          @default(0) // 0 = unlimited
  maxStorage     Int          @default(0) // MB, 0 = unlimited
  maxKnowledgeBooks Int       @default(0) // 0 = unlimited
  termsAndConditions String   @default("")
  updatedAt      DateTime     @updatedAt
}

// ── Estimator Personas ───────────────────────────────────────────────────

model EstimatorPersona {
  id               String       @id @default(cuid())
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name             String
  trade            String       @default("mechanical")
  description      String       @default("")
  systemPrompt     String       @default("")
  knowledgeBookIds Json         @default("[]")
  datasetTags      Json         @default("[]")
  isDefault        Boolean      @default(false)
  enabled          Boolean      @default(true)
  order            Int          @default(0)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([organizationId])
}

// ── Users & Auth ──────────────────────────────────────────────────────────

model User {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email          String
  name           String
  role           String       @default("estimator")
  active         Boolean      @default(true)
  passwordHash   String       @default("")
  lastLoginAt    DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  activities Activity[]
  sessions   Session[]

  @@unique([organizationId, email])
  @@index([organizationId])
}

model SuperAdmin {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sessions Session[]
}

model Session {
  id             String        @id @default(cuid())
  token          String        @unique
  userId         String?
  user           User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  superAdminId   String?
  superAdmin     SuperAdmin?   @relation(fields: [superAdminId], references: [id], onDelete: Cascade)
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  expiresAt      DateTime
  createdAt      DateTime      @default(now())
  userAgent      String        @default("")
  ipAddress      String        @default("")

  @@index([token])
  @@index([userId])
  @@index([expiresAt])
}

// ── Projects ──────────────────────────────────────────────────────────────

model Project {
  id               String       @id @default(cuid())
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name             String
  clientName       String       @default("")
  location         String       @default("")
  packageName      String       @default("")
  packageUploadedAt String      @default("")
  ingestionStatus  String       @default("queued")
  scope            String       @default("")
  summary          String       @default("")
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  sourceDocuments    SourceDocument[]
  quotes             Quote[]
  fileNodes          FileNode[]
  aiRuns             AiRun[]
  citations          Citation[]
  activities         Activity[]
  jobs               Job[]
  packages           StoredPackage[]
  ingestionJobs      IngestionJob[]
  workspaceState     WorkspaceState?
  pluginExecutions   PluginExecution[]
  takeoffAnnotations TakeoffAnnotation[]
  scheduleTasks      ScheduleTask[]

  @@index([organizationId])
}

model SourceDocument {
  id             String   @id @default(cuid())
  projectId      String
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  fileName       String
  fileType       String   @default("")
  documentType   String   @default("reference")
  pageCount      Int      @default(0)
  checksum       String   @default("")
  storagePath    String   @default("")
  extractedText  String   @default("")
  structuredData Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  citations Citation[]

  @@index([projectId])
}

// ── Quotes & Revisions ────────────────────────────────────────────────────

model Quote {
  id                       String   @id @default(cuid())
  projectId                String
  project                  Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  quoteNumber              String   @default("")
  title                    String   @default("")
  status                   String   @default("draft")
  currentRevisionId        String   @default("")
  customerExistingNew      String   @default("New")
  customerId               String?
  customer                 Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  customerString           String   @default("")
  customerContactId        String?
  customerContact          CustomerContact? @relation(fields: [customerContactId], references: [id], onDelete: SetNull)
  customerContactString    String   @default("")
  customerContactEmailString String @default("")
  departmentId             String?
  department               Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  userId                   String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  revisions QuoteRevision[]

  @@index([projectId])
  @@index([customerId])
  @@index([departmentId])
}

model QuoteRevision {
  id                    String   @id @default(cuid())
  quoteId               String
  quote                 Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  revisionNumber        Int      @default(0)
  title                 String   @default("")
  description           String   @default("")
  notes                 String   @default("")
  breakoutStyle         String   @default("grand_total")
  phaseWorksheetEnabled Boolean  @default(false)
  useCalculatedTotal    Boolean  @default(false)
  type                  String   @default("Firm")
  scratchpad            String   @default("")
  leadLetter            String   @default("")
  dateEstimatedShip     String?
  dateQuote             String?
  dateDue               String?
  dateWalkdown          String?
  dateWorkStart         String?
  dateWorkEnd           String?
  shippingMethod        String   @default("")
  shippingTerms         String   @default("")
  freightOnBoard        String   @default("")
  status                String   @default("Open")
  defaultMarkup         Float    @default(0)
  necaDifficulty        String   @default("")
  followUpNote          String   @default("")
  printEmptyNotesColumn Boolean  @default(false)
  printCategory         String[] @default([])
  printPhaseTotalOnly   Boolean  @default(false)
  showOvertimeDoubletime Boolean @default(false)
  grandTotal            Float    @default(0)
  regHours              Float    @default(0)
  overHours             Float    @default(0)
  doubleHours           Float    @default(0)
  subtotal              Float    @default(0)
  cost                  Float    @default(0)
  estimatedProfit       Float    @default(0)
  estimatedMargin       Float    @default(0)
  calculatedTotal       Float    @default(0)
  totalHours            Float    @default(0)
  breakoutPackage       Json     @default("[]")
  calculatedCategoryTotals Json  @default("[]")
  pdfPreferences        Json     @default("{}")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  worksheets      Worksheet[]
  phases          Phase[]
  modifiers       Modifier[]
  additionalLineItems AdditionalLineItem[]
  summaryRows     SummaryRow[]
  conditions      Condition[]
  reportSections  ReportSection[]
  scheduleTasks   ScheduleTask[]
  rateSchedules   RateSchedule[]

  @@index([quoteId])
}

// ── Worksheets & Items ────────────────────────────────────────────────────

model Worksheet {
  id         String        @id @default(cuid())
  revisionId String
  revision   QuoteRevision @relation(fields: [revisionId], references: [id], onDelete: Cascade)
  name       String        @default("Worksheet 1")
  order      Int           @default(0)

  items WorksheetItem[]

  @@index([revisionId])
}

model WorksheetItem {
  id             String    @id @default(cuid())
  worksheetId    String
  worksheet      Worksheet @relation(fields: [worksheetId], references: [id], onDelete: Cascade)
  phaseId        String?
  category       String    @default("Material")
  entityType     String    @default("Material")
  entityName     String    @default("")
  vendor         String?
  description    String    @default("")
  quantity       Float     @default(0)
  uom            String    @default("EA")
  cost           Float     @default(0)
  markup         Float     @default(0)
  price          Float     @default(0)
  unit1   Float     @default(0)  @map("laborHourReg")
  unit2   Float     @default(0)  @map("laborHourOver")
  unit3   Float     @default(0)  @map("laborHourDouble")
  lineOrder           Int      @default(0)
  rateScheduleItemId  String?
  itemId              String?  // FK to CatalogItem (for catalog-backed categories)
  tierUnits           Json     @default("{}")
  sourceNotes         String   @default("")

  @@index([worksheetId])
  @@index([phaseId])
}

// ── Phases ────────────────────────────────────────────────────────────────

model Phase {
  id          String        @id @default(cuid())
  revisionId  String
  revision    QuoteRevision @relation(fields: [revisionId], references: [id], onDelete: Cascade)
  number      String        @default("")
  name        String        @default("")
  description String        @default("")
  order       Int           @default(0)
  startDate   String?
  endDate     String?
  color       String        @default("")

  @@index([revisionId])
}

// ── Schedule Tasks ──────────────────────────────────────────────────────

model ScheduleTask {
  id            String        @id @default(cuid())
  projectId     String
  project       Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  revisionId    String
  revision      QuoteRevision @relation(fields: [revisionId], references: [id], onDelete: Cascade)
  phaseId       String?
  name          String        @default("")
  description   String        @default("")
  taskType      String        @default("task")
  status        String        @default("not_started")
  startDate     String?
  endDate       String?
  duration      Int           @default(0)
  progress      Float         @default(0)
  assignee      String        @default("")
  order         Int           @default(0)
  baselineStart String?
  baselineEnd   String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  predecessors  ScheduleDependency[] @relation("successorTask")
  successors    ScheduleDependency[] @relation("predecessorTask")

  @@index([projectId])
  @@index([revisionId])
  @@index([phaseId])
}

model ScheduleDependency {
  id            String       @id @default(cuid())
  predecessorId String
  predecessor   ScheduleTask @relation("predecessorTask", fields: [predecessorId], references: [id], onDelete: Cascade)
  successorId   String
  successor     ScheduleTask @relation("successorTask", fields: [successorId], references: [id], onDelete: Cascade)
  type          String       @default("FS")
  lagDays       Int          @default(0)

  @@unique([predecessorId, successorId])
  @@index([predecessorId])
  @@index([successorId])
}

// ── Modifiers ─────────────────────────────────────────────────────────────

model Modifier {
  id         String        @id @default(cuid())
  revisionId String
  revision   QuoteRevision @relation(fields: [revisionId], references: [id], onDelete: Cascade)
  name       String        @default("")
  type       String        @default("percentage")
  appliesTo  String        @default("All")
  percentage Float?
  amount     Float?
  show       String        @default("Yes")

  @@index([revisionId])
}

// ── Additional Line Items ─────────────────────────────────────────────────

model AdditionalLineItem {
  id          String        @id @default(cuid())
  revisionId  String
  revision    QuoteRevision @relation(fields: [revisionId], references: [id], onDelete: Cascade)
  name        String        @default("")
  description String?
  type        String        @default("LineItemAdditional")
  amount      Float         @default(0)

  @@index([revisionId])
}

// ── Summary Rows ──────────────────────────────────────────────────────────

model SummaryRow {
  id              String        @id @default(cuid())
  revisionId      String
  revision        QuoteRevision @relation(fields: [revisionId], references: [id], onDelete: Cascade)

  type            String        @default("manual")    // auto_category | auto_phase | manual | modifier | subtotal | separator
  label           String        @default("")
  order           Int           @default(0)
  visible         Boolean       @default(true)
  style           String        @default("normal")    // normal | bold | indent | highlight

  // Auto source
  sourceCategory  String?
  sourcePhase     String?

  // Manual rows: direct value entry
  manualValue     Float?
  manualCost      Float?

  // Auto row override: pin a value on auto rows instead of aggregating
  overrideValue   Float?
  overrideCost    Float?

  // Modifier fields
  modifierPercent Float?
  modifierAmount  Float?
  appliesTo       String[]      @default([])           // row IDs or ["all"]

  // Computed (filled by recalculate)
  computedValue   Float         @default(0)
  computedCost    Float         @default(0)
  computedMargin  Float         @default(0)

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([revisionId])
  @@map("summary_rows")
}

// ── Conditions ────────────────────────────────────────────────────────────

model Condition {
  id         String        @id @default(cuid())
  revisionId String
  revision   QuoteRevision @relation(fields: [revisionId], references: [id], onDelete: Cascade)
  type       String        @default("inclusion")
  value      String        @default("")
  order      Int           @default(0)

  @@index([revisionId])
}

// ── Rate Schedules ───────────────────────────────────────────────────────

model RateSchedule {
  id               String         @id @default(cuid())
  organizationId   String
  organization     Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name             String
  description      String         @default("")
  category         String         @default("labour")
  scope            String         @default("global")
  projectId        String?
  revisionId       String?
  revision         QuoteRevision? @relation(fields: [revisionId], references: [id], onDelete: Cascade)
  sourceScheduleId String?
  effectiveDate    String?
  expiryDate       String?
  defaultMarkup    Float          @default(0)
  autoCalculate    Boolean        @default(true)
  metadata         Json           @default("{}")
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  travelPolicyId   String?
  travelPolicy     TravelPolicy? @relation(fields: [travelPolicyId], references: [id])

  tiers RateScheduleTier[]
  items RateScheduleItem[]

  @@index([organizationId])
  @@index([revisionId])
}

model RateScheduleTier {
  id         String       @id @default(cuid())
  scheduleId String
  schedule   RateSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  name       String
  multiplier Float        @default(1.0)
  sortOrder  Int          @default(0)

  @@index([scheduleId])
}

model RateScheduleItem {
  id            String       @id @default(cuid())
  scheduleId    String
  schedule      RateSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  catalogItemId String?
  code          String       @default("")
  name          String       @default("")
  unit          String       @default("HR")
  rates         Json         @default("{}")
  costRates     Json         @default("{}")
  burden        Float        @default(0)
  perDiem       Float        @default(0)
  metadata      Json         @default("{}")
  sortOrder     Int          @default(0)

  @@index([scheduleId])
}

// ── Labour Cost & Burden ─────────────────────────────────────────────────

model LabourCostTable {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  description    String       @default("")
  effectiveDate  String?
  expiryDate     String?
  metadata       Json         @default("{}")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  entries LabourCostEntry[]

  @@index([organizationId])
}

model LabourCostEntry {
  id        String          @id @default(cuid())
  tableId   String
  table     LabourCostTable @relation(fields: [tableId], references: [id], onDelete: Cascade)
  code      String          @default("")
  name      String          @default("")
  group     String          @default("")
  costRates Json            @default("{}")
  metadata  Json            @default("{}")
  sortOrder Int             @default(0)

  @@index([tableId])
}

model BurdenPeriod {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String       @default("")
  group          String       @default("")
  percentage     Float        @default(0)
  startDate      String
  endDate        String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
}

// ── Travel Policy ────────────────────────────────────────────────────────

model TravelPolicy {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  description    String       @default("")

  // Per diem
  perDiemRate      Float   @default(0)
  perDiemEmbedMode String  @default("separate")
  hoursPerDay      Float   @default(8)

  // Travel time
  travelTimeHours Float @default(0)
  travelTimeTrips Int   @default(1)

  // Distance & fuel
  kmToDestination        Float @default(0)
  mileageRate            Float @default(0)
  fuelSurchargePercent   Float @default(0)
  fuelSurchargeAppliesTo String @default("labour")

  // Accommodation
  accommodationRate   Float @default(0)
  accommodationNights Int   @default(0)

  // Display
  showAsSeparateLine Boolean @default(true)
  breakoutLabel      String  @default("Travel & Per Diem")

  metadata  Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rateSchedules RateSchedule[]

  @@index([organizationId])
}

// ── Report Sections ───────────────────────────────────────────────────────

model ReportSection {
  id              String        @id @default(cuid())
  revisionId      String
  revision        QuoteRevision @relation(fields: [revisionId], references: [id], onDelete: Cascade)
  sectionType     String        @default("text")
  title           String        @default("")
  content         String        @default("")
  order           Int           @default(0)
  parentSectionId String?

  @@index([revisionId])
}

// ── Jobs ──────────────────────────────────────────────────────────────────

model Job {
  id             String   @id @default(cuid())
  projectId      String
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  revisionId     String   @default("")
  name           String   @default("")
  foreman        String   @default("")
  projectManager String   @default("")
  startDate      String?
  shipDate       String?
  poNumber       String   @default("")
  poIssuer       String   @default("")
  status         String   @default("Draft")
  createdAt      DateTime @default(now())

  @@index([projectId])
}

// ── File Nodes ────────────────────────────────────────────────────────────

model FileNode {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parentId    String?
  name        String
  type        String   @default("file")
  scope       String   @default("project") // "project" | "knowledge"
  fileType    String?
  size        Int?
  documentId  String?
  storagePath String?
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   String?

  @@index([projectId])
  @@index([parentId])
  @@index([scope])
}

// ── Takeoff Annotations ──────────────────────────────────────────────────

model TakeoffAnnotation {
  id              String   @id @default(cuid())
  projectId       String
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  documentId      String
  pageNumber      Int
  annotationType  String   // linear, linear-polyline, linear-drop, count, count-by-distance, area-vertical-wall, area-rectangle, area-triangle, area-ellipse, area-polygon
  label           String   @default("")
  color           String   @default("#3b82f6")
  lineThickness   Float    @default(4)
  visible         Boolean  @default(true)
  groupName       String   @default("")
  points          Json     @default("[]")
  measurement     Json     @default("{}")
  calibration     Json?
  metadata        Json     @default("{}")
  createdBy       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([projectId])
  @@index([documentId])
}

// ── AI Runs ───────────────────────────────────────────────────────────────

model AiRun {
  id            String   @id @default(cuid())
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  revisionId    String?
  kind          String
  status        String   @default("queued")
  model         String   @default("")
  promptVersion String   @default("")
  input         Json     @default("{}")
  output        Json     @default("{}")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([projectId])
}

// ── Citations ─────────────────────────────────────────────────────────────

model Citation {
  id               String          @id @default(cuid())
  projectId        String
  project          Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  aiRunId          String?
  sourceDocumentId String?
  sourceDocument   SourceDocument? @relation(fields: [sourceDocumentId], references: [id], onDelete: SetNull)
  resourceType     String          @default("source_document")
  resourceKey      String          @default("")
  pageStart        Int?
  pageEnd          Int?
  excerpt          String          @default("")
  confidence       Float           @default(0)

  @@index([projectId])
}

// ── Activities ────────────────────────────────────────────────────────────

model Activity {
  id         String   @id @default(cuid())
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  revisionId String?
  type       String
  data       Json     @default("{}")
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())

  @@index([projectId])
}

// ── Catalogs ──────────────────────────────────────────────────────────────

model Catalog {
  id               String        @id @default(cuid())
  organizationId   String?
  organization     Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name             String
  kind             String
  scope            String        @default("global")
  projectId        String?
  description      String        @default("")
  source           String        @default("manual")
  sourceDescription String       @default("")
  isTemplate       Boolean       @default(false)
  sourceTemplateId String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  items CatalogItem[]

  @@index([organizationId])
  @@index([isTemplate])
}

model CatalogItem {
  id        String   @id @default(cuid())
  catalogId String
  catalog   Catalog  @relation(fields: [catalogId], references: [id], onDelete: Cascade)
  code      String   @default("")
  name      String   @default("")
  unit      String   @default("")
  unitCost  Float    @default(0)
  unitPrice Float    @default(0)
  metadata  Json     @default("{}")
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([catalogId])
}

// ── Condition Library (global per-org) ────────────────────────────────────

model ConditionLibraryEntry {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  type           String
  value          String

  @@index([organizationId])
}

// ── Plugins ───────────────────────────────────────────────────────────────

model Plugin {
  id                  String       @id @default(cuid())
  organizationId      String
  organization        Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name                String
  slug                String
  icon                String?
  category            String       @default("general")
  description         String       @default("")
  llmDescription      String?
  version             String       @default("1.0.0")
  author              String?
  enabled             Boolean      @default(true)
  config              Json         @default("{}")
  configSchema        Json?
  toolDefinitions     Json         @default("[]")
  defaultOutputType   String?
  supportedCategories String[]     @default([])
  tags                String[]     @default([])
  documentation       String?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  executions PluginExecution[]

  @@unique([organizationId, slug])
  @@index([organizationId])
}

model PluginExecution {
  id                String   @id @default(cuid())
  pluginId          String
  plugin            Plugin   @relation(fields: [pluginId], references: [id], onDelete: Cascade)
  toolId            String
  projectId         String
  project           Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  revisionId        String
  worksheetId       String?
  input             Json     @default("{}")
  formState         Json?
  output            Json     @default("{}")
  appliedLineItemIds String[] @default([])
  status            String   @default("pending")
  error             String?
  executedBy        String?
  agentSessionId    String?
  createdAt         DateTime @default(now())

  @@index([projectId])
  @@index([pluginId])
}

// ── Knowledge ─────────────────────────────────────────────────────────────

model KnowledgeBook {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  description    String       @default("")
  category       String       @default("general")
  scope          String       @default("global")
  projectId      String?
  pageCount      Int          @default(0)
  chunkCount     Int          @default(0)
  status         String       @default("uploading")
  sourceFileName String       @default("")
  sourceFileSize Int          @default(0)
  storagePath    String?
  metadata       Json         @default("{}")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  chunks KnowledgeChunk[]

  @@index([organizationId])
}

model KnowledgeChunk {
  id           String        @id @default(cuid())
  bookId       String
  book         KnowledgeBook @relation(fields: [bookId], references: [id], onDelete: Cascade)
  pageNumber   Int?
  sectionTitle String        @default("")
  text         String        @default("")
  tokenCount   Int           @default(0)
  order        Int           @default(0)
  metadata     Json          @default("{}")

  @@index([bookId])
}

// ── Datasets ──────────────────────────────────────────────────────────────

model Dataset {
  id                String        @id @default(cuid())
  organizationId    String?
  organization      Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name              String
  description       String        @default("")
  category          String        @default("custom")
  scope             String        @default("global")
  projectId         String?
  columns           Json          @default("[]")
  rowCount          Int           @default(0)
  source            String        @default("manual")
  sourceDescription String        @default("")
  sourceBookId      String?       // Link back to KnowledgeBook this was extracted from
  sourcePages       String        @default("") // Page range(s) e.g. "85-87, 100"
  tags              String[]      @default([]) // Rich tags for search: ["pipe", "flange", "man-hours", "carbon-steel"]
  isTemplate        Boolean       @default(false)
  sourceTemplateId  String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  rows DatasetRow[]

  @@index([organizationId])
  @@index([isTemplate])
}

model DatasetRow {
  id        String   @id @default(cuid())
  datasetId String
  dataset   Dataset  @relation(fields: [datasetId], references: [id], onDelete: Cascade)
  data      Json     @default("{}")
  order     Int      @default(0)
  metadata  Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([datasetId])
}

// ── Entity Categories ─────────────────────────────────────────────────────

model EntityCategory {
  id              String       @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name            String
  entityType      String
  shortform       String       @default("")
  defaultUom      String       @default("EA")
  validUoms       String[]     @default([])
  editableFields  Json         @default("{}")
  unitLabels      Json         @default("{}")  @map("laborHourLabels")
  calculationType String       @default("manual")
  calcFormula     String       @default("") // custom formula expression for "formula" calc type
  itemSource      String       @default("freeform") // "rate_schedule" | "catalog" | "freeform"
  catalogId       String?      // When itemSource="catalog", which catalog backs this category
  color           String       @default("#6b7280")
  order           Int          @default(0)
  isBuiltIn       Boolean      @default(false)
  enabled         Boolean      @default(true)

  @@unique([organizationId, name])
  @@index([organizationId])
}

// ── Package & Ingestion Tracking ──────────────────────────────────────────

model StoredPackage {
  id               String   @id @default(cuid())
  projectId        String
  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  packageName      String   @default("")
  originalFileName String   @default("")
  sourceKind       String   @default("project")
  storagePath      String   @default("")
  reportPath       String?
  chunksPath       String?
  checksum         String   @default("")
  totalBytes       Int      @default(0)
  status           String   @default("uploaded")
  documentCount    Int      @default(0)
  chunkCount       Int      @default(0)
  documentIds      String[] @default([])
  unknownFiles     String[] @default([])
  uploadedAt       DateTime @default(now())
  ingestedAt       DateTime?
  updatedAt        DateTime @updatedAt
  error            String?

  @@index([projectId])
}

model IngestionJob {
  id          String    @id @default(cuid())
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  packageId   String?
  kind        String
  status      String    @default("queued")
  progress    Int       @default(0)
  input       Json      @default("{}")
  output      Json?
  error       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  startedAt   DateTime?
  completedAt DateTime?
  storagePath String?

  @@index([projectId])
}

// ── Workspace State (UI preferences per project) ──────────────────────────

model WorkspaceState {
  id        String   @id @default(cuid())
  projectId String   @unique
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  state     Json     @default("{}")
  updatedAt DateTime @updatedAt
}

// ── Customers ─────────────────────────────────────────────────────────────

model Customer {
  id               String       @id @default(cuid())
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name             String
  shortName        String       @default("")
  phone            String       @default("")
  email            String       @default("")
  website          String       @default("")
  addressStreet    String       @default("")
  addressCity      String       @default("")
  addressProvince  String       @default("")
  addressPostalCode String      @default("")
  addressCountry   String       @default("")
  notes            String       @default("")
  active           Boolean      @default(true)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  contacts CustomerContact[]
  quotes   Quote[]

  @@index([organizationId])
}

model CustomerContact {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  name       String
  title      String   @default("")
  phone      String   @default("")
  email      String   @default("")
  isPrimary  Boolean  @default(false)
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  quotes Quote[]

  @@index([customerId])
}

// ── Departments ───────────────────────────────────────────────────────────

model Department {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  code           String       @default("")
  description    String       @default("")
  active         Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  quotes Quote[]

  @@index([organizationId])
}
