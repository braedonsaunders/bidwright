    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "tsx src/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.6.0"
  },
  "devDependencies": {
    "@prisma/adapter-pg": "^7.5.0",
    "pg": "^8.20.0",
    "prisma": "^6.6.0",
    "tsx": "^4.19.2"
  }
}
