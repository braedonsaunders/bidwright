COMPOSE_PROJECT_NAME=bidwright

POSTGRES_USER=bidwright
POSTGRES_PASSWORD=change-me
POSTGRES_DB=bidwright
DATABASE_URL=postgresql://bidwright:change-me@postgres:5432/bidwright
REDIS_URL=redis://redis:6379

POSTGRES_DATA_PATH=/opt/bidwright/data/postgres
REDIS_DATA_PATH=/opt/bidwright/data/redis
OLLAMA_DATA_PATH=/opt/bidwright/data/ollama
BIDWRIGHT_DATA_PATH=/opt/bidwright/data/app
DATA_DIR=/data

API_PORT=3001
API_PUBLIC_PORT=3101
WEB_PUBLIC_PORT=3100
NEXT_PUBLIC_API_BASE_URL=http://10.0.0.74:3101

DEFAULT_ORG_ID=org-bidwright-seed

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

ANTHROPIC_API_KEY=
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-20250514

EMBEDDING_PROVIDER=local
EMBEDDING_BASE_URL=http://ollama:11434/v1
EMBEDDING_MODEL=snowflake-arctic-embed
EMBEDDING_DIMENSIONS=1024

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_FROM_NAME=Bidwright
