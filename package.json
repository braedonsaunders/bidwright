{
  "name": "bidwright",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev": "bash scripts/dev/start-dev.sh",
    "dev:windows": "powershell -ExecutionPolicy Bypass -File scripts/dev/dev.ps1",
    "dev:apps": "pnpm --parallel --filter @bidwright/web --filter @bidwright/api --filter @bidwright/worker dev",
    "dev:web": "pnpm --filter @bidwright/web dev",
    "dev:api": "pnpm --filter @bidwright/api dev",
    "dev:worker": "pnpm --filter @bidwright/worker dev",
    "model-editor:install": "npm --prefix apps/model-editor ci",
    "model-editor:build": "npm --prefix apps/model-editor run build && powershell -ExecutionPolicy Bypass -File scripts/model-editor/sync-built-assets.ps1",
    "build": "pnpm run model-editor:build && pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "db:generate": "pnpm --filter @bidwright/db db:generate",
    "db:push": "pnpm --filter @bidwright/db db:push",
    "db:seed": "pnpm --filter @bidwright/db db:seed",
    "db:migrate": "pnpm --filter @bidwright/db db:migrate",
    "seed": "tsx scripts/db/seed-db.ts",
    "deploy:export": "powershell -ExecutionPolicy Bypass -File scripts/deploy/export-local-state.ps1",
    "docker:up": "docker compose -f docker-compose.prod.yml up --build -d",
    "docker:down": "docker compose -f docker-compose.prod.yml down",
    "docker:logs": "docker compose -f docker-compose.prod.yml logs -f"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "argon2",
      "msgpackr-extract"
    ]
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "pg": "^8.20.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
